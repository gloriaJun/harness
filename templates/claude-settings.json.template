{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git revert:*)",
      "Bash(gh api:*)",
      "Bash(gh auth:*)",
      "Bash(pnpm nx:*)",
      "Bash(pnpm exec:*)",
      "Bash(brew install:*)",
      "Bash(brew upgrade:*)",
      "mcp__chrome-devtools",
      "mcp__mcp-github"
    ],
    "deny": [],
    "defaultMode": "plan",
    "additionalDirectories": []
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {}
}
